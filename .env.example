# Frontend-only override (optional). Default is /api/ai/generate.
VITE_AI_GATEWAY_URL=/api/ai/generate

# Local gateway runner options (optional, local Node script only).
MUN_AI_GATEWAY_PORT=8787
MUN_AI_GATEWAY_ORIGIN=*

# Optional OpenRouter referer used server-side by gateway calls.
MUN_OPENROUTER_REFERER=

# Optional local health script overrides.
MUN_AI_GATEWAY_URL=http://127.0.0.1:8787/api/ai/health
MUN_SOURCE_PROBE_URL=http://127.0.0.1:8787/api/sources/restcountries/v3.1/name/azerbaijan?fields=name
